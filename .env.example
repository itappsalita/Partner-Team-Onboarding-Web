# -----------------------------------------------------------------------------
# Partner Team Onboarding System - Environment Configuration Example
# -----------------------------------------------------------------------------
# Copy this file to .env.local (for local dev) or .env.production (for prod)
# and fill in the values. NEVER commit secrets to version control.

# URL Koneksi Database (MySQL)
# Local: mysql://root:password@localhost:3306/db_name
# Docker: mysql://root:password@db:3306/db_name
DATABASE_URL="mysql://user:password@host:port/database"

# Next Auth Configuration
# Generate a secret using: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Google AI API Key (For Gemini/KT-OCR Features)
# Get one at: https://aistudio.google.com/
GOOGLE_AI_API_KEY="your-api-key-here"

# SMTP Configuration (For Email Notifications/Reset Password)
SMTP_HOST="smtp.yourprovider.com"
SMTP_PORT=587
SMTP_USER="your-email@domain.com"
SMTP_PASSWORD="your-email-password"
